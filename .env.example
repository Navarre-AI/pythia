# Copy to .env for local dev. In production, set these with `fly secrets set`.
# Never commit a real .env; it is gitignored.

# Claude API (server-side only)
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Optional; defaults to claude-fable-5
# ANTHROPIC_MODEL=claude-fable-5

# Site password gate (Basic auth, or ?key= for FileMaker web viewers)
SITE_PASSWORD=choose-a-password

# FileMaker Server (a read-access account; OData must be enabled — see SETUP.md).
# Leave all four unset to play with the bundled fictional sample dataset instead.
FM_HOST=your.filemaker.host
FM_DB=YourDatabase
FM_USER=pythia
FM_PASS=account-password

# Bounds (defaults shown)
PORT=8080
FM_TIMEOUT_MS=15000
